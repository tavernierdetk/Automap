# ---------------------------------------------------------------------------
# Automap .gitignore
# The #1 rule: drone footage (~1.24 GB) and all pipeline intermediates NEVER
# enter git. Only the toolchain (scripts, config, docs, Godot project) is
# version-controlled.
# ---------------------------------------------------------------------------

# Input footage and all stage intermediates
input/*
work/*

# ...but keep the empty drop-zones tracked
!input/.gitkeep
!work/.gitkeep

# Large 3D / media binaries, wherever they land
*.mp4
*.mov
*.srt
*.obj
*.glb
*.gltf
*.ply
*.las
*.laz
*.tif
*.tiff

# Godot import cache & (re)generated assets. The glb and the textures Godot
# extracts from it are rebuilt by stage 4 from work/mesh/ — not git's job.
godot/.godot/
godot/assets/*
!godot/assets/.gitkeep

# Generation output/intermediates must NEVER live inside the Godot project — the
# engine loads glbs from work/ by path (generation & playback are decoupled). If a
# scene tree ever gets copied in here, keep its frames/odm/glbs out of git.
godot/scenes/*/frames/
godot/scenes/*/odm/
godot/scenes/**/*.glb
godot/scenes/**/*.jpg
godot/scenes/**/*.png

# Generated scene registry — points to local, regenerated glbs (format documented
# in docs/explorations/named-ingestion.md). Local state, like work/.
scenes/manifest.json

# Python
.venv/
__pycache__/
*.pyc
.pytest_cache/

# macOS
.DS_Store
